<?xml version="1.0"?>
<robot name="puzzlebot">

  <!-- =========================================================
       MATERIALS
  ========================================================= -->
  <material name="white_transparent">
    <color rgba="1.0 1.0 1.0 0.5"/>
  </material>

  <material name="white_wheel">
    <color rgba="1.0 1.0 1.0 0.7"/>
  </material>

  <material name="gray">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>


  <!-- =========================================================
       LINKS
  ========================================================= -->

  <!-- odom (world reference, no inertia / geometry needed) -->
  <link name="odom"/>

  <!-- base_footprint: robot footprint on the ground plane -->
  <link name="base_footprint"/>

  <!-- base_link: main chassis -->
  <link name="base_link">
    <visual>
      <!-- mesh is rotated 90 deg around Z to match the marker offset (yaw = 1.57 rad) -->
      <origin xyz="0.0 0.0 -0.01" rpy="0.0 0.0 1.57"/>
      <geometry>
        <mesh filename="package://puzzlebot_urdf_ROS/meshes/Puzzlebot_Jetson_Lidar_Edition_Base.stl"
              scale="1 1 1"/>
      </geometry>
      <material name="white_transparent"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <!-- Approximate bounding box — adjust to your actual chassis dimensions -->
        <box size="0.19 0.15 0.10"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <mass value="1.0"/>
      <!-- Approximate inertia for a 0.19 x 0.15 x 0.10 box, mass = 1 kg -->
      <inertia ixx="0.002729" ixy="0.0" ixz="0.0"
               iyy="0.004302" iyz="0.0"
               izz="0.006292"/>
    </inertial>
  </link>

  <!-- wheel_r: right drive wheel -->
  <link name="wheel_r">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="package://puzzlebot_urdf_ROS/meshes/Puzzlebot_Wheel.stl"
              scale="1 1 1"/>
      </geometry>
      <material name="white_wheel"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="1.5708 0.0 0.0"/>
      <geometry>
        <!-- Approximate wheel cylinder — adjust radius/length as needed -->
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0000833" ixy="0.0" ixz="0.0"
               iyy="0.0000833" iyz="0.0"
               izz="0.000125"/>
    </inertial>
  </link>

  <!-- wheel_l: left drive wheel -->
  <link name="wheel_l">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="package://puzzlebot_urdf_ROS/meshes/Puzzlebot_Wheel.stl"
              scale="1 1 1"/>
      </geometry>
      <material name="white_wheel"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="1.5708 0.0 0.0"/>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0000833" ixy="0.0" ixz="0.0"
               iyy="0.0000833" iyz="0.0"
               izz="0.000125"/>
    </inertial>
  </link>

  <!-- caster: passive front/rear caster wheel -->
  <link name="caster">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="package://puzzlebot_urdf_ROS/meshes/Puzzlebot_Caster_Wheel.stl"
              scale="1 1 1"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <mass value="0.05"/>
      <inertia ixx="0.000006" ixy="0.0" ixz="0.0"
               iyy="0.000006" iyz="0.0"
               izz="0.000006"/>
    </inertial>
  </link>


  <!-- =========================================================
       JOINTS
  ========================================================= -->

  <!-- odom → base_footprint  (fixed; motion is published via /odom topic) -->
  <joint name="odom_to_base_footprint" type="fixed">
    <parent link="odom"/>
    <child  link="base_footprint"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
  </joint>

  <!-- base_footprint → base_link
       Translation taken from timer_cb:  z = 0.06 m (chassis lift off ground)
       Rotation is identity at rest (yaw controlled at runtime).              -->
  <joint name="base_footprint_to_base_link" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0.0 0.0 0.06" rpy="0.0 0.0 0.0"/>
  </joint>

  <!-- base_link → wheel_r
       From define_TF:
         x =  0.084  (forward offset)
         y =  0.053  (lateral offset to the right)
         z =  0.05 - 0.06 = -0.01
       Continuous joint: spins around local X axis (axle direction).          -->
  <joint name="base_link_to_wheel_r" type="continuous">
    <parent link="base_link"/>
    <child  link="wheel_r"/>
    <origin xyz="0.084 0.053 -0.01" rpy=" 3.1416  1.5708 0.0"/>
    <!-- Wheel axle points along the world Y axis when the robot is upright -->
    <axis xyz="0 0 1"/>
  </joint>

  <!-- base_link → wheel_l
       From define_TF:
         x = -0.084  (forward offset, opposite side)
         y =  0.053
         z = -0.01                                                            -->
  <joint name="base_link_to_wheel_l" type="continuous">
    <parent link="base_link"/>
    <child  link="wheel_l"/>
    <origin xyz="-0.084 0.053 -0.01" rpy="0 1.5708 0.0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- base_link → caster
       From define_TF:
         x =  0.0
         y = -0.075  (rear)
         z =  0.005 - 0.06 = -0.055                                          -->
  <joint name="base_link_to_caster" type="fixed">
    <parent link="base_link"/>
    <child  link="caster"/>
    <origin xyz="0.0 -0.075 -0.055" rpy="0.0 0.0 0.0"/>
  </joint>

</robot>
